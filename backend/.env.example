# Backend environment variables (copy to backend/.env in local dev)

# App mode: development | production
APP_ENV=development

# JWT signing key (REQUIRED in production)
# Use a long random string, at least 32 chars.
JWT_SECRET_KEY=change-this-secret-before-deploy

# Optional: comma-separated previous keys used during rotation.
# Keep old key(s) here for a short grace period so existing tokens remain valid,
# then remove old keys after expiration window.
JWT_PREVIOUS_SECRET_KEYS=

# CORS configuration
CORS_ALLOW_ALL=0
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Upload limits
MAX_DOC_UPLOAD_MB=10
MAX_TEMPLATE_UPLOAD_MB=20

# Google Sign-In (id_token audience verification)
# Must match frontend VITE_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Frontend URL used by Google OAuth callback redirect
FRONTEND_URL=http://localhost:5173

# Premium self-subscription package
PREMIUM_SELF_SUBSCRIBE_DAYS=30
PREMIUM_SELF_SUBSCRIBE_TOKEN_COST=12000

# Timeouts and cleanup
SSE_CLEANUP_DELAY_SECONDS=3600
LATEX_COMPILE_TIMEOUT_SECONDS=30

# Cleanup TTL (hours)
TEMP_TTL_HOURS=6
OUTPUT_TTL_HOURS=24

# SePay Payment Gateway
SEPAY_API_KEY="paste_api_key_here"
NAME_WEB="W2L"
SECRET_XOR_KEY=0x5EAFB
