# Backend environment variables (copy to backend/.env in local dev)

# App mode: development | production
APP_ENV=development

# JWT signing key (REQUIRED in production)
# Use a long random string, at least 32 chars.
JWT_SECRET_KEY=change-this-secret-before-deploy

# Optional: comma-separated previous keys used during rotation.
# Keep old key(s) here for a short grace period so existing tokens remain valid,
# then remove old keys after expiration window.
JWT_PREVIOUS_SECRET_KEYS=

# CORS configuration
CORS_ALLOW_ALL=0
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Cleanup TTL (hours)
TEMP_TTL_HOURS=6
OUTPUT_TTL_HOURS=24
