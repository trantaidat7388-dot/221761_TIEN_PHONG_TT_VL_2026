# Frontend environment variables
# Sao chép file này thành .env và điền thông tin của bạn

# Google Sign-In Web Client ID
VITE_GOOGLE_CLIENT_ID=

# SePay QR Bank Config (Thông tin ngân hàng để hiển thị QR cho khách nạp tiền)
# Tra mã BIN tại: https://api.vietqr.io/v2/banks
VITE_BANK_BIN=970422
VITE_BANK_ACCOUNT=0123456789
VITE_BANK_ACCOUNT_NAME=TRAN TAN DAT